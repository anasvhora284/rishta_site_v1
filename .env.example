# Supabase (required for frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Required for normal admin self-service password reset (/admin/reset-password)
VITE_ADMIN_PASSWORD_RESET_GATE=your-team-reset-code

# Migration / admin scripts only (never expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
